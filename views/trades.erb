<h2>Trade History</h2>
<p class="subtitle">Append-only log of every buy and sell. Sells include FIFO realized P&amp;L per lot closed, holding-period classification (short / long), and wash-sale risk flags.</p>

<section class="portfolio-summary">
  <div class="summary-card">
    <div class="summary-label">Realized P&amp;L (YTD)</div>
    <div class="summary-value mono <%= @realized_ytd >= 0 ? 'positive' : 'negative' %>">
      <%= format_money(@realized_ytd) %>
    </div>
  </div>
  <div class="summary-card">
    <div class="summary-label">Short-term (YTD)</div>
    <div class="summary-value mono <%= @realized_short_ytd >= 0 ? 'positive' : 'negative' %>">
      <%= format_money(@realized_short_ytd) %>
    </div>
    <div class="summary-sub muted">Held ≤ 1 yr · ordinary-income tax</div>
  </div>
  <div class="summary-card">
    <div class="summary-label">Long-term (YTD)</div>
    <div class="summary-value mono <%= @realized_long_ytd >= 0 ? 'positive' : 'negative' %>">
      <%= format_money(@realized_long_ytd) %>
    </div>
    <div class="summary-sub muted">Held > 1 yr · cap-gains rate</div>
  </div>
  <div class="summary-card">
    <div class="summary-label">All time</div>
    <div class="summary-value mono <%= @realized_total >= 0 ? 'positive' : 'negative' %>">
      <%= format_money(@realized_total) %>
    </div>
  </div>
  <div class="summary-card">
    <div class="summary-label">Trades</div>
    <div class="summary-value mono"><%= @trades.length %></div>
  </div>
</section>

<form method="GET" action="/trades" class="compare-form" style="margin-bottom: 16px;">
  <label>
    <span class="field-label">Filter by symbol</span>
    <input type="text" name="symbol" value="<%= @symbol %>" placeholder="AAPL" autocomplete="off" maxlength="10">
  </label>
  <button type="submit" class="refresh-btn">Filter</button>
  <% if @symbol %><a href="/trades" class="refresh-btn" style="margin-left:6px">Clear</a><% end %>
</form>

<% if @trades.empty? %>
  <div class="notice">No trades recorded yet<%= @symbol ? " for #{@symbol}" : '' %>. Buys and sells from /portfolio will appear here.</div>
<% else %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Date</th>
        <th>Symbol</th>
        <th>Side</th>
        <th class="num">Shares</th>
        <th class="num">Price</th>
        <th class="num">Realized P&amp;L</th>
        <th>Holding</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      <% @trades.reverse.each do |t| %>
        <%
          is_sell = t[:side] == 'sell'
          # Holding-period summary across closed lots: 'short', 'long',
          # 'mixed' if both, '—' for buys.
          period = if is_sell && t[:lots_closed]
                     periods = Array(t[:lots_closed]).map { |l| (l[:holding_period] || l['holding_period']).to_s }.compact.uniq
                     periods.length > 1 ? 'mixed' : (periods.first || 'unknown')
                   else
                     nil
                   end
        %>
        <tr>
          <td class="mono"><%= t[:date] %></td>
          <td><a href="/analysis/<%= t[:symbol] %>"><%= t[:symbol] %></a></td>
          <td>
            <span class="signal-badge <%= t[:side] == 'buy' ? 'signal-buy' : 'signal-sell' %>">
              <%= t[:side].upcase %>
            </span>
          </td>
          <td class="num mono"><%= t[:shares] %></td>
          <td class="num mono">$<%= format('%.2f', t[:price]) %></td>
          <td class="num mono <%= t[:realized_pl] && t[:realized_pl] >= 0 ? 'positive' : (t[:realized_pl] && t[:realized_pl] < 0 ? 'negative' : '') %>">
            <% if is_sell && t[:realized_pl] %>
              <%= format_money(t[:realized_pl]) %>
              <% if t[:short_term_pl] && t[:long_term_pl] && (t[:short_term_pl].to_f != 0) && (t[:long_term_pl].to_f != 0) %>
                <div class="muted" style="font-size: 0.78rem">
                  ST <%= format_money(t[:short_term_pl]) %> · LT <%= format_money(t[:long_term_pl]) %>
                </div>
              <% end %>
            <% else %>
              <span class="muted">—</span>
            <% end %>
          </td>
          <td>
            <% if period %>
              <span class="signal-badge holding-<%= period %>"><%= period %></span>
              <% if t[:wash_sale_flags] && !t[:wash_sale_flags].empty? %>
                <span class="signal-badge holding-wash" title="<%= WashSale.summarize_flag(t[:wash_sale_flags].first.transform_keys(&:to_sym)) %>">
                  wash sale ⚠
                </span>
              <% end %>
            <% else %>
              <span class="muted">—</span>
            <% end %>
          </td>
          <td class="muted"><%= t[:notes] %></td>
        </tr>
        <% if t[:wash_sale_flags] && !t[:wash_sale_flags].empty? %>
          <tr class="wash-sale-detail-row">
            <td colspan="8">
              <div class="wash-sale-warning">
                <% Array(t[:wash_sale_flags]).each do |flag_raw| %>
                  <% flag = flag_raw.is_a?(Hash) ? flag_raw.transform_keys(&:to_sym) : flag_raw %>
                  <% flag[:matching_buy] = (flag[:matching_buy] || flag['matching_buy']).transform_keys(&:to_sym) if (flag[:matching_buy] || flag['matching_buy']).is_a?(Hash) %>
                  <%= WashSale.summarize_flag(flag) %><br>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
<% end %>
