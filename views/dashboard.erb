<div class="page-header">
  <div>
    <h2>Dashboard</h2>
    <p class="subtitle">Global market overview</p>
  </div>
  <form method="POST" action="/refresh/dashboard" style="display: inline;">
    <button type="submit" class="refresh-btn">🔄 Refresh Data</button>
  </form>
</div>

<% if @macro && @macro.values.any? %>
<section class="analysis-section">
  <h3>Macro Snapshot</h3>
  <table class="summary-table data-table">
    <thead>
      <tr>
        <th>Series</th>
        <th class="num">Value</th>
        <th>As of</th>
      </tr>
    </thead>
    <tbody>
      <% macro_cards = [
        [:fed_funds,     'Fed Funds Rate',       '%'],
        [:treasury_3mo,  '3-Month Treasury',     '%'],
        [:treasury_10yr, '10-Year Treasury',     '%'],
        [:cpi,           'CPI (Index Level)',    nil],
        [:unemployment,  'Unemployment Rate',    '%'],
        [:vix,           'VIX',                  nil]
      ] %>
      <% macro_cards.each do |key, label, unit| %>
        <% row = @macro[key] %>
        <% next unless row %>
        <tr>
          <td><%= label %></td>
          <td class="num mono"><%= row[:value] %><%= unit %></td>
          <td class="muted mono"><%= row[:date] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <p class="data-source">Source: FRED (St. Louis Fed)</p>
</section>
<% end %>

<% if @indices && !@indices.empty? %>
<section class="analysis-section">
  <h3>Indices</h3>
  <table class="summary-table data-table">
    <thead>
      <tr>
        <th>Index</th>
        <th>Region</th>
        <th class="num">Close</th>
        <th class="num">Change</th>
        <th class="num">Open</th>
        <th class="num">High</th>
        <th class="num">Low</th>
        <th>As of</th>
      </tr>
    </thead>
    <tbody>
      <% index_meta = {
        sp500:     ['S&P 500',    'US'],
        nasdaq:    ['Nasdaq Composite', 'US'],
        dow:       ['Dow Jones Industrial Avg.', 'US'],
        nikkei:    ['Nikkei 225', 'Japan'],
        hang_seng: ['Hang Seng',  'Hong Kong'],
        dax:       ['DAX',        'Germany'],
        ftse:      ['FTSE 100',   'UK'],
        cac:       ['CAC 40',     'France']
      } %>
      <% @indices.each do |key, row| %>
        <% next unless row %>
        <% label, region = index_meta[key] || [key.to_s, '—'] %>
        <% chg = (row[:open] && row[:close] && row[:open] != 0) ? ((row[:close] - row[:open]) / row[:open] * 100) : nil %>
        <tr>
          <td><%= label %></td>
          <td class="muted"><%= region %></td>
          <td class="num mono"><%= row[:close] ? format('%.2f', row[:close]) : '—' %></td>
          <td class="num mono <%= chg && chg >= 0 ? 'positive' : chg ? 'negative' : '' %>">
            <%= chg ? format('%+.2f%%', chg) : '—' %>
          </td>
          <td class="num mono muted"><%= row[:open] ? format('%.2f', row[:open]) : '—' %></td>
          <td class="num mono muted"><%= row[:high] ? format('%.2f', row[:high]) : '—' %></td>
          <td class="num mono muted"><%= row[:low]  ? format('%.2f', row[:low])  : '—' %></td>
          <td class="muted mono"><%= row[:date] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <p class="data-source">Source: Stooq</p>
</section>
<% end %>

<%= erb :_symbol_table, locals: { quotes: @data[:quotes] } %>

<div class="chart-row">
  <div class="chart-box">
    <h3>Price Overview</h3>
    <canvas id="dashboardChart"></canvas>
  </div>
</div>

<script>
  // Wait for Chart.js to be fully loaded
  window.addEventListener('load', function() {
    const dashData = <%= @data[:quotes].to_json %>;
    if (typeof Chart !== 'undefined') {
      renderSummaryChart('dashboardChart', dashData);
    } else {
      console.error('Chart.js not loaded');
    }
  });
</script>

<% if @signals && !@signals.empty? %>
<section class="market-signals-section">
  <h3>Market Signals</h3>
  <div class="signal-cards">
    <% @signals.each do |s| %>
    <div class="signal-card signal-card-<%= s[:signal].downcase %>">
      <div class="signal-card-header">
        <a href="/analysis/<%= s[:symbol] %>" class="signal-card-symbol"><%= s[:symbol] %></a>
        <span class="signal signal-<%= s[:signal].downcase %>"><%= s[:signal] %></span>
      </div>
      <div class="signal-card-meta">
        <span class="signal-card-region"><%= s[:region] %></span>
        <span class="signal-card-price"><%= s[:price] %></span>
        <span class="signal-card-change <%= s[:change].to_f >= 0 ? 'positive' : 'negative' %>"><%= s[:change] %></span>
      </div>
      <% if s[:analyst] %>
      <div class="analyst-summary">
        <span class="analyst-type"><%= s[:signal_type] %></span>
        <span class="analyst-counts">
          SB:<%= s[:analyst][:strong_buy] %>
          B:<%= s[:analyst][:buy] %>
          H:<%= s[:analyst][:hold] %>
          S:<%= s[:analyst][:sell] %>
          SS:<%= s[:analyst][:strong_sell] %>
        </span>
      </div>
      <% else %>
      <div class="analyst-summary">
        <span class="analyst-type"><%= s[:signal_type] %></span>
      </div>
      <% end %>
      <p class="signal-card-rationale"><%= s[:rationale] %></p>
      <a href="/analysis/<%= s[:symbol] %>" class="view-analysis-link">View Analysis &rarr;</a>
    </div>
    <% end %>
  </div>
</section>
<% end %>
