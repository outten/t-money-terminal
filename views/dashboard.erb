<div class="page-header">
  <div>
    <h2>Dashboard</h2>
    <p class="subtitle">Global market overview</p>
  </div>
  <form method="POST" action="/refresh/dashboard" style="display: inline;">
    <button type="submit" class="refresh-btn">🔄 Refresh Data</button>
  </form>
</div>

<% if @macro && @macro.values.any? %>
<section class="macro-panel">
  <h3>Macro Snapshot</h3>
  <div class="macro-grid">
    <% macro_cards = [
      [:fed_funds,     'Fed Funds',     '%'],
      [:treasury_3mo,  '3-Mo Treasury', '%'],
      [:treasury_10yr, '10-Yr Treasury','%'],
      [:cpi,           'CPI (Index)',   nil],
      [:unemployment,  'Unemployment',  '%'],
      [:vix,           'VIX',           nil]
    ] %>
    <% macro_cards.each do |key, label, unit| %>
      <% row = @macro[key] %>
      <% next unless row %>
      <div class="macro-card">
        <span class="field-label"><%= label %></span>
        <span class="field-value"><%= row[:value] %><%= unit %></span>
        <span class="macro-date"><%= row[:date] %></span>
      </div>
    <% end %>
  </div>
  <p class="data-source">Source: FRED (St. Louis Fed)</p>
</section>
<% end %>

<% if @intl_indices && !@intl_indices.empty? %>
<section class="macro-panel">
  <h3>International Indices</h3>
  <div class="macro-grid">
    <% index_labels = { nikkei: 'Nikkei 225', dax: 'DAX', ftse: 'FTSE 100', cac: 'CAC 40', hang_seng: 'Hang Seng' } %>
    <% @intl_indices.each do |key, row| %>
      <div class="macro-card">
        <span class="field-label"><%= index_labels[key] || key.to_s %></span>
        <span class="field-value"><%= row[:close] ? format('%.2f', row[:close]) : '—' %></span>
        <span class="macro-date"><%= row[:date] %></span>
      </div>
    <% end %>
  </div>
  <p class="data-source">Source: Stooq</p>
</section>
<% end %>

<%= erb :_symbol_table, locals: { quotes: @data[:quotes] } %>

<div class="chart-row">
  <div class="chart-box">
    <h3>Price Overview</h3>
    <canvas id="dashboardChart"></canvas>
  </div>
</div>

<script>
  // Wait for Chart.js to be fully loaded
  window.addEventListener('load', function() {
    const dashData = <%= @data[:quotes].to_json %>;
    if (typeof Chart !== 'undefined') {
      renderSummaryChart('dashboardChart', dashData);
    } else {
      console.error('Chart.js not loaded');
    }
  });
</script>

<% if @signals && !@signals.empty? %>
<section class="market-signals-section">
  <h3>Market Signals</h3>
  <div class="signal-cards">
    <% @signals.each do |s| %>
    <div class="signal-card signal-card-<%= s[:signal].downcase %>">
      <div class="signal-card-header">
        <a href="/analysis/<%= s[:symbol] %>" class="signal-card-symbol"><%= s[:symbol] %></a>
        <span class="signal signal-<%= s[:signal].downcase %>"><%= s[:signal] %></span>
      </div>
      <div class="signal-card-meta">
        <span class="signal-card-region"><%= s[:region] %></span>
        <span class="signal-card-price"><%= s[:price] %></span>
        <span class="signal-card-change <%= s[:change].to_f >= 0 ? 'positive' : 'negative' %>"><%= s[:change] %></span>
      </div>
      <% if s[:analyst] %>
      <div class="analyst-summary">
        <span class="analyst-type"><%= s[:signal_type] %></span>
        <span class="analyst-counts">
          SB:<%= s[:analyst][:strong_buy] %>
          B:<%= s[:analyst][:buy] %>
          H:<%= s[:analyst][:hold] %>
          S:<%= s[:analyst][:sell] %>
          SS:<%= s[:analyst][:strong_sell] %>
        </span>
      </div>
      <% else %>
      <div class="analyst-summary">
        <span class="analyst-type"><%= s[:signal_type] %></span>
      </div>
      <% end %>
      <p class="signal-card-rationale"><%= s[:rationale] %></p>
      <a href="/analysis/<%= s[:symbol] %>" class="view-analysis-link">View Analysis &rarr;</a>
    </div>
    <% end %>
  </div>
</section>
<% end %>
