<% if @stale_banner %>
<div class="stale-banner">
  <span class="stale-icon">&#9888;</span> <%= @stale_banner %>
</div>
<% end %>

<div class="analysis-header">
  <div class="analysis-title">
    <h2><%= @symbol %></h2>
    <% if @profile && @profile[:name] %>
    <p class="analysis-name"><%= @profile[:name] %></p>
    <% end %>
  </div>
  <div class="analysis-header-right">
    <div class="analysis-signal-badge">
      <span class="signal signal-<%= @signal.downcase %> signal-lg"><%= @signal %></span>
      <span class="signal-type-label"><%= @signal_type %></span>
    </div>
    <form method="POST" action="/refresh/analysis/<%= @symbol %>" style="display: inline;">
      <button type="submit" class="refresh-btn" title="Bust cache and reload live data">
        &#8635; Refresh
      </button>
    </form>
  </div>
</div>

<!-- Analyst Consensus -->
<section class="analysis-section">
  <h3>Analyst Consensus</h3>
  <% if @analyst %>
  <% total = (@analyst[:strong_buy].to_i + @analyst[:buy].to_i + @analyst[:hold].to_i + @analyst[:sell].to_i + @analyst[:strong_sell].to_i).to_f %>
  <% total = 1.0 if total == 0 %>
  <div class="analyst-grid">
    <% [[:strong_buy, 'Strong Buy', 'bullish'], [:buy, 'Buy', 'bullish'], [:hold, 'Hold', 'neutral'], [:sell, 'Sell', 'bearish'], [:strong_sell, 'Strong Sell', 'bearish']].each do |key, label, cls| %>
    <div class="analyst-row">
      <span class="analyst-label"><%= label %></span>
      <div class="analyst-bar-wrap">
        <div class="analyst-bar analyst-bar-<%= cls %>" style="width:<%= (@analyst[key].to_i / total * 100).round %>%"></div>
      </div>
      <span class="analyst-count"><%= @analyst[key] %></span>
    </div>
    <% end %>
  </div>
  <% if @analyst[:period] %>
  <p class="data-source">Source: Finnhub — period: <%= @analyst[:period] %></p>
  <% else %>
  <p class="data-source">Source: Finnhub</p>
  <% end %>
  <% else %>
  <p class="no-data">No analyst consensus data available for this symbol.</p>
  <% end %>
</section>

<!-- Company Profile -->
<section class="analysis-section">
  <h3>Company Profile</h3>
  <% if @profile %>
  <div class="profile-grid">
    <% if @profile[:description] %>
    <div class="profile-description">
      <p><%= @profile[:description] %></p>
    </div>
    <% end %>
    <div class="profile-fields">
      <% unless @profile[:exchange].to_s.empty? %>
      <div class="profile-field"><span class="field-label">Exchange</span><span class="field-value"><%= @profile[:exchange] %></span></div>
      <% end %>
      <% unless @profile[:industry].to_s.empty? %>
      <div class="profile-field"><span class="field-label">Industry</span><span class="field-value"><%= @profile[:industry] %></span></div>
      <% end %>
      <% if @profile[:market_cap] && @profile[:market_cap].to_f > 0 %>
      <% mc = @profile[:market_cap].to_f %>
      <% mc_ccy = @profile[:market_cap_currency].to_s.upcase %>
      <% mc_sym = case mc_ccy when 'JPY' then '¥' when 'EUR' then '€' when 'GBP' then '£' else '$' end %>
      <% mc_str = mc >= 1_000_000 ? "#{mc_sym}#{'%.2f' % (mc / 1_000_000)}T" : mc >= 1_000 ? "#{mc_sym}#{'%.2f' % (mc / 1_000)}B" : "#{mc_sym}#{'%.0f' % mc}M" %>
      <% mc_label = (mc_ccy.empty? || mc_ccy == 'USD') ? 'Market Cap' : "Market Cap (#{mc_ccy})" %>
      <div class="profile-field"><span class="field-label"><%= mc_label %></span><span class="field-value"><%= mc_str %></span></div>
      <% end %>
      <% if @profile[:ipo] && !@profile[:ipo].to_s.empty? %>
      <div class="profile-field"><span class="field-label">IPO Date</span><span class="field-value"><%= @profile[:ipo] %></span></div>
      <% end %>
    </div>
  </div>
  <p class="data-source">Source: Finnhub</p>
  <% if @profile[:weburl] && !@profile[:weburl].to_s.strip.empty? %>
  <div class="profile-homepage">
    <a href="<%= @profile[:weburl] %>" target="_blank" rel="noopener noreferrer" class="ext-link">Website &rarr;</a>
  </div>
  <% end %>
  <% else %>
  <p class="no-data">No profile data available for this symbol.</p>
  <% end %>
</section>

<!-- Key Financials from Quote -->
<section class="analysis-section">
  <h3>Key Financials</h3>
  <div class="profile-grid">
    <div class="profile-fields">
      <% price  = @quote['05. price']          || @quote[:price]          || 'N/A' %>
      <% change = @quote['10. change percent'] || @quote[:change]         || 'N/A' %>
      <% high   = @quote['03. high']           || @quote[:high]           || 'N/A' %>
      <% low    = @quote['04. low']            || @quote[:low]            || 'N/A' %>
      <% open   = @quote['02. open']           || @quote[:open]           || 'N/A' %>
      <div class="profile-field"><span class="field-label">Price</span><span class="field-value"><%= price %></span></div>
      <div class="profile-field"><span class="field-label">Change</span><span class="field-value <%= change.to_f >= 0 ? 'positive' : 'negative' %>"><%= change %></span></div>
      <div class="profile-field"><span class="field-label">Open</span><span class="field-value"><%= open %></span></div>
      <div class="profile-field"><span class="field-label">High</span><span class="field-value"><%= high %></span></div>
      <div class="profile-field"><span class="field-label">Low</span><span class="field-value"><%= low %></span></div>
    </div>
  </div>
  <p class="data-source">Source: Tiingo / Alpha Vantage / Finnhub / Yahoo Finance</p>
</section>

<!-- Key Metrics & Ratios (FMP) -->
<% if @key_metrics || @ratios %>
<section class="analysis-section">
  <h3>Fundamentals & Ratios</h3>
  <div class="profile-grid">
    <div class="profile-fields">
      <% m = @key_metrics || {} %>
      <% r = @ratios || {} %>
      <% pe   = r[:priceToEarningsRatio] %>
      <% pb   = r[:priceToBookRatio] %>
      <% ps   = r[:priceToSalesRatio] %>
      <% roe  = m[:returnOnEquity] || r[:returnOnEquity] %>
      <% roa  = m[:returnOnAssets] || r[:returnOnAssets] %>
      <% de   = r[:debtToEquityRatio] %>
      <% cr   = m[:currentRatio] || r[:currentRatio] %>
      <% gm   = r[:grossProfitMargin] %>
      <% om   = r[:operatingProfitMargin] %>
      <% nm   = r[:netProfitMargin] %>
      <% dy   = r[:dividendYield] %>
      <% fcfy = m[:freeCashFlowYield] %>
      <% eyp  = m[:earningsYield] %>
      <div class="profile-field"><span class="field-label">P/E</span><span class="field-value"><%= format_ratio(pe) %></span></div>
      <div class="profile-field"><span class="field-label">P/B</span><span class="field-value"><%= format_ratio(pb) %></span></div>
      <div class="profile-field"><span class="field-label">P/S</span><span class="field-value"><%= format_ratio(ps) %></span></div>
      <div class="profile-field"><span class="field-label">ROE</span><span class="field-value"><%= format_percent(roe) %></span></div>
      <div class="profile-field"><span class="field-label">ROA</span><span class="field-value"><%= format_percent(roa) %></span></div>
      <div class="profile-field"><span class="field-label">Debt / Equity</span><span class="field-value"><%= format_ratio(de) %></span></div>
      <div class="profile-field"><span class="field-label">Current Ratio</span><span class="field-value"><%= format_ratio(cr) %></span></div>
      <div class="profile-field"><span class="field-label">Gross Margin</span><span class="field-value"><%= format_percent(gm) %></span></div>
      <div class="profile-field"><span class="field-label">Operating Margin</span><span class="field-value"><%= format_percent(om) %></span></div>
      <div class="profile-field"><span class="field-label">Net Margin</span><span class="field-value"><%= format_percent(nm) %></span></div>
      <div class="profile-field"><span class="field-label">Dividend Yield</span><span class="field-value"><%= format_percent(dy) %></span></div>
      <div class="profile-field"><span class="field-label">FCF Yield</span><span class="field-value"><%= format_percent(fcfy) %></span></div>
      <div class="profile-field"><span class="field-label">Earnings Yield</span><span class="field-value"><%= format_percent(eyp) %></span></div>
    </div>
  </div>
  <p class="data-source">Source: Financial Modeling Prep — period: <%= (m[:date] || r[:date] || 'latest') %></p>
</section>
<% end %>

<!-- DCF Intrinsic Value (FMP) -->
<% if @dcf %>
<section class="analysis-section">
  <h3>DCF Valuation</h3>
  <% intrinsic = @dcf[:dcf].to_f %>
  <% current   = @dcf[:'Stock Price']&.to_f || @dcf[:stockPrice].to_f %>
  <% margin    = current.zero? ? nil : (intrinsic - current) / current %>
  <div class="profile-grid">
    <div class="profile-fields">
      <div class="profile-field"><span class="field-label">Intrinsic (DCF)</span><span class="field-value">$<%= format('%.2f', intrinsic) %></span></div>
      <div class="profile-field"><span class="field-label">Market Price</span><span class="field-value">$<%= format('%.2f', current) %></span></div>
      <% if margin %>
      <div class="profile-field">
        <span class="field-label">Margin of Safety</span>
        <span class="field-value <%= margin >= 0 ? 'positive' : 'negative' %>"><%= format_percent(margin, digits: 1) %></span>
      </div>
      <% end %>
      <div class="profile-field"><span class="field-label">Valuation Date</span><span class="field-value"><%= @dcf[:date] || '—' %></span></div>
    </div>
  </div>
  <p class="data-source">Source: Financial Modeling Prep DCF</p>
</section>
<% end %>

<!-- Upcoming Earnings (FMP) -->
<% if @earnings %>
<section class="analysis-section">
  <h3>Upcoming Earnings</h3>
  <div class="profile-grid">
    <div class="profile-fields">
      <div class="profile-field"><span class="field-label">Date</span><span class="field-value"><%= @earnings[:date] %></span></div>
      <% if @earnings[:epsEstimated] %>
      <div class="profile-field"><span class="field-label">EPS Estimate</span><span class="field-value"><%= format_ratio(@earnings[:epsEstimated]) %></span></div>
      <% end %>
      <% if @earnings[:revenueEstimated] %>
      <div class="profile-field"><span class="field-label">Revenue Estimate</span><span class="field-value"><%= format_money(@earnings[:revenueEstimated]) %></span></div>
      <% end %>
      <% if @earnings[:time] %>
      <div class="profile-field"><span class="field-label">Time</span><span class="field-value"><%= @earnings[:time].to_s.upcase %></span></div>
      <% end %>
    </div>
  </div>
  <p class="data-source">Source: Financial Modeling Prep — earnings calendar</p>
</section>
<% end %>

<!-- Latest News (Finnhub / NewsAPI) -->
<% if @news && !@news.empty? %>
<section class="analysis-section">
  <h3>Latest News</h3>
  <ul class="news-list">
    <% @news.each do |article| %>
    <li class="news-item">
      <a href="<%= article[:url] %>" target="_blank" rel="noopener noreferrer" class="news-headline"><%= article[:headline] %></a>
      <div class="news-meta">
        <span class="news-source"><%= article[:source] %></span>
        <% if article[:datetime] %>
        <span class="news-date"><%= (Time.parse(article[:datetime].to_s).strftime('%b %d, %H:%M') rescue article[:datetime]) %></span>
        <% end %>
      </div>
      <% if article[:summary] && !article[:summary].to_s.strip.empty? %>
      <p class="news-summary"><%= article[:summary] %></p>
      <% end %>
    </li>
    <% end %>
  </ul>
  <p class="data-source">Source: Finnhub company news (NewsAPI fallback)</p>
</section>
<% end %>

<!-- Technical Indicators (Analytics::Indicators) -->
<% if @analytics[:indicators] && @analytics[:indicators][:latest_close] %>
<% ind = @analytics[:indicators] %>
<section class="analysis-section">
  <h3>Technical Indicators</h3>
  <table class="summary-table data-table">
    <thead>
      <tr>
        <th>Indicator</th>
        <th class="num">Value</th>
        <th>Signal</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Price vs SMA 50</td>
        <td class="num mono"><%= ind[:sma50] ? format('%.2f', ind[:sma50]) : '—' %></td>
        <td class="<%= ind[:sma50] && ind[:latest_close] >= ind[:sma50] ? 'positive' : 'negative' %>">
          <% if ind[:sma50] %>
            <%= ind[:latest_close] >= ind[:sma50] ? 'Price above SMA 50' : 'Price below SMA 50' %>
          <% else %>—<% end %>
        </td>
      </tr>
      <tr>
        <td>Price vs SMA 200</td>
        <td class="num mono"><%= ind[:sma200] ? format('%.2f', ind[:sma200]) : '—' %></td>
        <td class="<%= ind[:sma200] && ind[:latest_close] >= ind[:sma200] ? 'positive' : 'negative' %>">
          <% if ind[:sma200] %>
            <%= ind[:latest_close] >= ind[:sma200] ? 'Price above SMA 200' : 'Price below SMA 200' %>
          <% else %>Insufficient history<% end %>
        </td>
      </tr>
      <tr>
        <td>RSI (14)</td>
        <td class="num mono"><%= ind[:rsi14] ? format('%.1f', ind[:rsi14]) : '—' %></td>
        <td class="<%= ind[:rsi14] && ind[:rsi14] > 70 ? 'negative' : ind[:rsi14] && ind[:rsi14] < 30 ? 'positive' : '' %>">
          <%= rsi_label(ind[:rsi14]) %>
        </td>
      </tr>
      <tr>
        <td>MACD (12 / 26 / 9)</td>
        <td class="num mono">
          <%= ind[:macd] ? format('%.2f', ind[:macd]) : '—' %>
          / <%= ind[:macd_signal] ? format('%.2f', ind[:macd_signal]) : '—' %>
        </td>
        <td class="<%= ind[:macd_histogram] && ind[:macd_histogram] >= 0 ? 'positive' : 'negative' %>">
          <% if ind[:macd_histogram] %>
            <%= ind[:macd_histogram] >= 0 ? 'Bullish crossover' : 'Bearish crossover' %>
            (hist <%= format('%+.2f', ind[:macd_histogram]) %>)
          <% else %>—<% end %>
        </td>
      </tr>
      <tr>
        <td>Bollinger (20, 2σ)</td>
        <td class="num mono">
          <% if ind[:bb_upper] %>
            <%= format('%.2f', ind[:bb_lower]) %> — <%= format('%.2f', ind[:bb_upper]) %>
          <% else %>—<% end %>
        </td>
        <td><%= bollinger_position(ind[:latest_close], ind[:bb_upper], ind[:bb_middle], ind[:bb_lower]) %></td>
      </tr>
    </tbody>
  </table>
  <p class="data-source">Computed locally from cached historical closes.</p>
</section>
<% end %>

<!-- Risk & Performance (Analytics::Risk) -->
<% if @analytics[:risk] && @analytics[:risk][:annualized_return] %>
<% rk = @analytics[:risk] %>
<section class="analysis-section">
  <h3>Risk & Performance</h3>
  <table class="summary-table data-table">
    <thead>
      <tr>
        <th>Metric</th>
        <th class="num">Value</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Annualized Return</td>
        <td class="num mono <%= rk[:annualized_return] && rk[:annualized_return] >= 0 ? 'positive' : 'negative' %>">
          <%= format_percent(rk[:annualized_return]) %>
        </td>
        <td class="muted">CAGR over window</td>
      </tr>
      <tr>
        <td>Annualized Volatility</td>
        <td class="num mono"><%= format_percent(rk[:annualized_volatility]) %></td>
        <td class="muted">σ of daily returns × √252</td>
      </tr>
      <tr>
        <td>Sharpe Ratio</td>
        <td class="num mono <%= rk[:sharpe] && rk[:sharpe] >= 1 ? 'positive' : rk[:sharpe] && rk[:sharpe] < 0 ? 'negative' : '' %>">
          <%= format_ratio(rk[:sharpe]) %>
        </td>
        <td class="muted">rf = <%= format_percent(rk[:risk_free_rate]) %> (FRED 3-Mo)</td>
      </tr>
      <tr>
        <td>Sortino Ratio</td>
        <td class="num mono"><%= format_ratio(rk[:sortino]) %></td>
        <td class="muted">Downside deviation only</td>
      </tr>
      <tr>
        <td>Max Drawdown</td>
        <td class="num mono negative"><%= format_percent(rk[:max_drawdown]) %></td>
        <td class="muted">Peak-to-trough loss</td>
      </tr>
      <tr>
        <td>VaR 95% (historical)</td>
        <td class="num mono negative"><%= format_percent(rk[:var_historical_95]) %></td>
        <td class="muted">5th-%ile daily return</td>
      </tr>
      <tr>
        <td>VaR 95% (parametric)</td>
        <td class="num mono negative"><%= format_percent(rk[:var_parametric_95]) %></td>
        <td class="muted">Normal-dist approximation</td>
      </tr>
      <% if rk[:beta_vs_spy] %>
      <tr>
        <td>Beta vs SPY</td>
        <td class="num mono"><%= format_ratio(rk[:beta_vs_spy]) %></td>
        <td class="muted">Sensitivity to market</td>
      </tr>
      <% end %>
    </tbody>
  </table>
  <p class="data-source">Computed locally from cached historical closes and FRED risk-free rate.</p>
</section>
<% end %>

<!-- Black-Scholes Illustration (Analytics::BlackScholes) -->
<% if @analytics[:bs] && !@analytics[:bs].empty? %>
<% bs = @analytics[:bs] %>
<section class="analysis-section">
  <h3>Black-Scholes (ATM, 30-day)</h3>
  <div class="profile-grid">
    <div class="profile-fields">
      <div class="profile-field"><span class="field-label">Strike (ATM)</span><span class="field-value">$<%= format('%.2f', bs[:strike]) %></span></div>
      <div class="profile-field"><span class="field-label">Expiry</span><span class="field-value"><%= bs[:expiry_days] %> days</span></div>
      <div class="profile-field"><span class="field-label">Historical σ</span><span class="field-value"><%= format_percent(bs[:historical_vol]) %></span></div>
      <div class="profile-field"><span class="field-label">Risk-Free Rate</span><span class="field-value"><%= format_percent(bs[:risk_free_rate]) %></span></div>
    </div>
  </div>
  <table class="summary-table data-table" style="margin-top: 0.75rem;">
    <thead>
      <tr>
        <th>Option</th>
        <th class="num">Price</th>
        <th class="num">Δ</th>
        <th class="num">Γ</th>
        <th class="num">Vega</th>
        <th class="num">Θ / day</th>
        <th class="num">ρ</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Call (ATM)</td>
        <td class="num mono">$<%= format('%.2f', bs[:call_price]) %></td>
        <td class="num mono"><%= format('%.3f', bs[:greeks][:delta]) %></td>
        <td class="num mono"><%= format('%.4f', bs[:greeks][:gamma]) %></td>
        <td class="num mono"><%= format('%.3f', bs[:greeks][:vega]) %></td>
        <td class="num mono negative"><%= format('%.3f', bs[:greeks][:theta]) %></td>
        <td class="num mono"><%= format('%.3f', bs[:greeks][:rho]) %></td>
      </tr>
      <tr>
        <td>Put (ATM)</td>
        <td class="num mono">$<%= format('%.2f', bs[:put_price]) %></td>
        <td colspan="5" class="muted">Put-call parity implied</td>
      </tr>
    </tbody>
  </table>
  <p class="data-source">European option model; σ from 1-year realised vol, r from FRED 3-Mo Treasury.</p>
</section>
<% end %>

<!-- External Links -->
<section class="analysis-section">
  <h3>External Research</h3>
  <div class="external-links">
    <a href="https://www.google.com/finance/quote/<%= @symbol %>" target="_blank" rel="noopener noreferrer" class="ext-link">Google Finance &rarr;</a>
    <a href="https://finance.yahoo.com/quote/<%= @symbol %>" target="_blank" rel="noopener noreferrer" class="ext-link">Yahoo Finance &rarr;</a>
    <a href="https://finviz.com/quote.ashx?t=<%= @symbol %>" target="_blank" rel="noopener noreferrer" class="ext-link">Finviz &rarr;</a>
  </div>
</section>

<!-- Historical Chart -->
<section class="analysis-section">
  <h3>Historical Price</h3>
  <div class="period-buttons">
    <% %w[1d 1m 3m ytd 1y 5y].each do |p| %>
    <button class="period-btn <%= p == '1y' ? 'active' : '' %>" data-period="<%= p %>" data-symbol="<%= @symbol %>"><%= p.upcase %></button>
    <% end %>
  </div>
  <div class="chart-box" id="historicalChartWrap">
    <canvas id="historicalChart"></canvas>
    <% if !@historical || @historical.empty? %>
    <p class="no-data chart-no-data">No historical data available. Try <a href="/analysis/<%= @symbol %>?refresh=1">refreshing</a>.</p>
    <% end %>
  </div>
  <p class="data-source">Source: Yahoo Finance / Tiingo / Alpha Vantage</p>
</section>

<script>
  window.addEventListener('load', function() {
    const initialData = <%= (@historical || []).to_json %>;
    const labels = initialData.map(function(d) { return d.date; });
    const prices  = initialData.map(function(d) { return d.close; });
    renderHistoricalChart('historicalChart', labels, prices);

    document.querySelectorAll('.period-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.period-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        const symbol = btn.dataset.symbol;
        const period = btn.dataset.period;
        fetch('/api/candle/' + symbol + '/' + period)
          .then(function(r) { return r.json(); })
          .then(function(data) {
            const lbl = data.map(function(d) { return d.date; });
            const pts = data.map(function(d) { return d.close; });
            renderHistoricalChart('historicalChart', lbl, pts);
          });
      });
    });
  });
</script>
