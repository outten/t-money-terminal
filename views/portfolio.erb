<h2>Portfolio</h2>
<p class="subtitle">
  Lot-based positions with live unrealized P&amp;L. Sells close shares FIFO and append to <a href="/trades">Trade History</a>.
  &middot; <a href="/portfolio/tax-harvest">Tax-loss harvesting →</a>
</p>

<% if @import_count && @import_count > 0 %>
  <div class="degradation-banner" role="status" style="background:#d1f0d1; color:#1d4620; border-color:#a3d8a3">
    <strong>✓ Imported <%= @import_count %> position<%= @import_count == 1 ? '' : 's' %></strong> from Fidelity
    <% if @import_file_date %>(<%= @import_file_date %>)<% end %>
    <% if @import_skipped && @import_skipped > 0 %>· <%= @import_skipped %> non-position rows skipped<% end %>.
    Lots replaced with broker average cost basis; quote cache primed<% if @import_prefetch && @import_prefetch > 0 %>;
    historicals prefetching for <%= @import_prefetch %> symbol<%= @import_prefetch == 1 ? '' : 's' %>
    in the background (<a href="/admin/health">progress</a>)<% end %>.
  </div>
<% elsif @backfill_count && @backfill_count > 0 %>
  <div class="degradation-banner" role="status" style="background:#d1f0d1; color:#1d4620; border-color:#a3d8a3">
    <strong>✓ Backfilled <%= @backfill_count %> snapshot<%= @backfill_count == 1 ? '' : 's' %></strong>
    from CSVs. The value-over-time chart and sparklines below now have history.
    <% if @backfill_errors && @backfill_errors > 0 %>
      <strong style="color:#a02020">· <%= @backfill_errors %> failed to parse</strong>
    <% end %>
  </div>
<% elsif params['imported_error'] %>
  <div class="degradation-banner" role="alert">
    <strong>Import failed:</strong> <%= params['imported_error'] %>
  </div>
<% end %>

<section class="fidelity-import" aria-label="Broker import">
  <form action="/portfolio/import/fidelity" method="post" class="fidelity-import-form">
    <button type="submit" class="btn-primary">Import latest Fidelity export</button>
    <span class="data-source">
      <% if @latest_fidelity %>
        Latest file: <code><%= File.basename(@latest_fidelity) %></code>
      <% else %>
        Drop a <code>Portfolio_Positions_*.csv</code> in <code>data/porfolio/fidelity/</code> first.
      <% end %>
      <% if @latest_snapshot %>
        &middot; Last imported:
        <strong><%= @latest_snapshot['file_date'] || @latest_snapshot['basename'] %></strong>
        <% if @latest_snapshot['written_at'] %>
          (<%= Time.parse(@latest_snapshot['written_at']).strftime('%Y-%m-%d %H:%M %Z') %>)
        <% end %>
        &middot; <%= (@latest_snapshot['positions'] || []).length %> positions in snapshot
        <% if @snapshot_count && @snapshot_count >= 2 %>
          &middot; <a href="/portfolio/drift">View drift</a>
        <% end %>
      <% end %>
    </span>
  </form>

  <% if @backfill_pending && @backfill_pending > 0 %>
    <form action="/portfolio/import/fidelity/backfill" method="post" class="fidelity-import-form" style="margin-top: 10px">
      <button type="submit" class="btn-primary"
              onclick="return confirm('Backfill <%= @backfill_pending %> CSV(s) into snapshots?\nThis only writes JSON snapshots — it does NOT change your current portfolio, quote cache, or trigger historical prefetch.');">
        Backfill <%= @backfill_pending %> CSV<%= @backfill_pending == 1 ? '' : 's' %> into snapshots
      </button>
      <span class="data-source">
        Found <%= @backfill_pending %> Fidelity CSV<%= @backfill_pending == 1 ? '' : 's' %> without a JSON snapshot — backfilling makes them appear in the value-over-time chart and per-position sparklines below. Won't touch your current portfolio.
      </span>
    </form>
  <% end %>
</section>

<% if @history_series && @history_series.length >= 2 %>
  <section class="benchmark-section" style="margin-top: 18px">
    <h3>Portfolio value over time
      <% latest = @history_series.last; first = @history_series.first %>
      <% total_chg = (latest[:total_value] - first[:total_value]).round(2) %>
      <% total_chg_pct = first[:total_value].positive? ? ((latest[:total_value] - first[:total_value]) / first[:total_value]) : nil %>
      <span class="muted" style="font-size:0.78rem; font-weight:normal">
        &middot; <%= @history_series.length %> snapshot<%= @history_series.length == 1 ? '' : 's' %>
        &middot; <%= first[:date] %> → <%= latest[:date] %>
        &middot; <span class="<%= total_chg >= 0 ? 'positive' : 'negative' %>">
          <%= format_money(total_chg) %><% if total_chg_pct %> (<%= format_percent(total_chg_pct) %>)<% end %>
        </span>
      </span>
    </h3>
    <div class="portfolio-summary">
      <% last_pt = @history_series.last %>
      <div class="summary-card">
        <div class="summary-label">Latest snapshot value</div>
        <div class="summary-value mono"><%= format_money(last_pt[:total_value]) %></div>
        <div class="summary-sub muted">on <%= last_pt[:date] %></div>
      </div>
      <% if last_pt[:day_change] %>
        <div class="summary-card">
          <div class="summary-label">Day-over-day change</div>
          <div class="summary-value mono <%= last_pt[:day_change] >= 0 ? 'positive' : 'negative' %>">
            <%= format_money(last_pt[:day_change]) %>
            <% if last_pt[:day_change_pct] %>
              <span class="summary-sub">(<%= format_percent(last_pt[:day_change_pct]) %>)</span>
            <% end %>
          </div>
          <div class="summary-sub muted">vs prior snapshot</div>
        </div>
      <% end %>
      <div class="summary-card">
        <div class="summary-label">Unrealized P&amp;L (latest)</div>
        <div class="summary-value mono <%= last_pt[:unrealized_pl] >= 0 ? 'positive' : 'negative' %>">
          <%= format_money(last_pt[:unrealized_pl]) %>
          <% if last_pt[:unrealized_pl_pct] %>
            <span class="summary-sub">(<%= format_percent(last_pt[:unrealized_pl_pct]) %>)</span>
          <% end %>
        </div>
      </div>
    </div>

    <div style="position: relative; height: 280px; margin-top: 14px">
      <canvas id="portfolio-history-chart" aria-label="Portfolio value over time"></canvas>
    </div>
    <p class="data-source">
      One data point per import, not per market day — gaps between imports aren't interpolated.
      Direction reflects total market value of all snapshot positions (broker-reported `current_value` when present).
    </p>
    <script>
      window.PORTFOLIO_HISTORY = <%= @history_series.to_json %>;
    </script>
  </section>
<% elsif @history_series && @history_series.length == 1 %>
  <section class="benchmark-section" style="margin-top: 18px">
    <h3>Portfolio value over time</h3>
    <p class="data-source">
      Only <strong>one snapshot</strong> on file (<%= @history_series.first[:date] %>) — at least two are needed for a trajectory. Drop more <code>Portfolio_Positions_*.csv</code> in <code>data/porfolio/fidelity/</code> and click the backfill button above.
    </p>
  </section>
<% end %>

<% if @movers && @movers[:window] && (@movers[:top_gainers].any? || @movers[:top_losers].any?) %>
  <section class="benchmark-section" style="margin-top: 18px">
    <h3>
      Performance leaders &amp; laggards
      <span class="muted" style="font-size:0.78rem; font-weight:normal">
        &middot; <%= @movers[:window][:from] %> → <%= @movers[:window][:to] %>
        &middot; <%= @movers[:window][:snapshots] %> snapshots
      </span>
    </h3>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px">
      <div>
        <h4 style="margin: 0 0 8px 0; font-size: 0.95rem">Top 5 gainers</h4>
        <% if @movers[:top_gainers].empty? %>
          <p class="muted">No gainers in this window.</p>
        <% else %>
          <table class="data-table" style="font-size: 0.88rem">
            <thead>
              <tr>
                <th>Symbol</th>
                <th class="num">Change</th>
                <th class="num">$ Δ</th>
                <th>Trend</th>
              </tr>
            </thead>
            <tbody>
              <% @movers[:top_gainers].each do |r| %>
                <tr>
                  <td><a href="/analysis/<%= r[:symbol] %>"><%= r[:symbol] %></a></td>
                  <td class="num mono positive"><%= format_percent(r[:change_pct]) %></td>
                  <td class="num mono positive"><%= format_money(r[:change_value]) %></td>
                  <td><%= PortfolioHistory.sparkline_svg(r[:series], width: 60, height: 18) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% end %>
      </div>
      <div>
        <h4 style="margin: 0 0 8px 0; font-size: 0.95rem">Top 5 laggards</h4>
        <% if @movers[:top_losers].empty? %>
          <p class="muted">No losers in this window — every position is up.</p>
        <% else %>
          <table class="data-table" style="font-size: 0.88rem">
            <thead>
              <tr>
                <th>Symbol</th>
                <th class="num">Change</th>
                <th class="num">$ Δ</th>
                <th>Trend</th>
              </tr>
            </thead>
            <tbody>
              <% @movers[:top_losers].each do |r| %>
                <tr>
                  <td><a href="/analysis/<%= r[:symbol] %>"><%= r[:symbol] %></a></td>
                  <td class="num mono negative"><%= format_percent(r[:change_pct]) %></td>
                  <td class="num mono negative"><%= format_money(r[:change_value]) %></td>
                  <td><%= PortfolioHistory.sparkline_svg(r[:series], width: 60, height: 18) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% end %>
      </div>
    </div>
    <p class="data-source">
      Ranked by % change in market value from the first snapshot to the latest. Window length depends on
      your snapshot cadence — see the value-over-time chart above for the full trajectory.
    </p>
  </section>
<% end %>

<% if @allocation && @allocation[:rows].any? %>
  <section class="benchmark-section" style="margin-top: 18px">
    <h3>
      Asset-class breakdown
      <span class="muted" style="font-size:0.78rem; font-weight:normal">
        &middot; <%= format_money(@allocation[:total_value]) %> total
        <% if @allocation[:as_of] %>&middot; as of <%= @allocation[:as_of] %><% end %>
      </span>
    </h3>
    <table class="data-table">
      <thead>
        <tr>
          <th>Class</th>
          <th class="num">Value</th>
          <th class="num">% of portfolio</th>
          <th class="num">Positions</th>
          <th>Top holdings</th>
        </tr>
      </thead>
      <tbody>
        <% @allocation[:rows].each do |r| %>
          <tr>
            <td>
              <strong><%= r[:label] %></strong>
              <% if r[:class] == 'unmapped' %>
                <span class="muted" style="font-size: 0.78rem">(not yet classified)</span>
              <% end %>
            </td>
            <td class="num mono"><%= format_money(r[:value]) %></td>
            <td class="num mono">
              <%= format_percent(r[:pct], digits: 1) %>
              <span class="muted" style="display: inline-block; vertical-align: middle; margin-left: 6px;
                                          background: #e0e0e0; height: 8px; width: 80px; position: relative">
                <span style="display: block; height: 100%; width: <%= (r[:pct] * 100).round(1) %>%;
                             background: <%=
                               { 'us_stocks' => '#0071e3', 'intl_stocks' => '#34c759',
                                 'bonds' => '#ff9500', 'real_estate' => '#af52de',
                                 'commodities' => '#ffcc00', 'target_date' => '#5ac8fa',
                                 'balanced' => '#a47148', 'cash' => '#999',
                                 'unmapped' => '#cc6680' }[r[:class]] || '#999' %>"></span>
              </span>
            </td>
            <td class="num mono"><%= r[:count] %></td>
            <td class="muted" style="font-size: 0.85rem">
              <%= r[:symbols].first(3).map { |s| "<a href='/analysis/#{s[:symbol]}'>#{s[:symbol]}</a>" }.join(' &middot; ') %>
              <% if r[:symbols].length > 3 %>
                &middot; +<%= r[:symbols].length - 3 %> more
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <p class="data-source">
      Classification uses a hand-curated symbol map plus description-text heuristics
      (e.g. "<em>FREEDOM 2035</em>" → target-date, "<em>EMERGING MARKETS</em>" → international, "<em>S&amp;P 500</em>" → US stocks).
      Anything we couldn't confidently map lands in <strong>unmapped</strong> — for big "unmapped" buckets, the symbol map
      in <code>app/asset_class_mapper.rb</code> is where to add coverage.
      Target-date / glide-path funds are reported as a single class even though they internally hold a stock+bond mix.
    </p>
  </section>
<% end %>

<% if @account_breakdown && @account_breakdown[:rows].any? %>
  <section class="benchmark-section" style="margin-top: 18px">
    <h3>
      Account-type allocation
      <span class="muted" style="font-size:0.78rem; font-weight:normal">
        &middot; <%= format_money(@account_breakdown[:total_value]) %> total
        <% if @account_breakdown[:as_of] %>&middot; as of <%= @account_breakdown[:as_of] %><% end %>
      </span>
    </h3>
    <table class="data-table">
      <thead>
        <tr>
          <th>Account</th>
          <th>Tax kind</th>
          <th class="num">Value</th>
          <th class="num">% of portfolio</th>
          <th class="num">Positions</th>
          <th>Top holdings</th>
        </tr>
      </thead>
      <tbody>
        <% @account_breakdown[:rows].each do |r| %>
          <tr>
            <td><strong><%= r[:account] %></strong></td>
            <td>
              <span class="signal-badge holding-<%=
                { 'taxable' => 'short', 'roth' => 'long',
                  'tax_deferred_401k' => 'long', 'traditional_ira' => 'long',
                  'deferred_annuity' => 'unknown', 'hsa' => 'long' }[r[:kind]] || 'unknown' %>"
                    title="<%= r[:kind] %>">
                <%= r[:kind_label] %>
              </span>
            </td>
            <td class="num mono"><%= format_money(r[:value]) %></td>
            <td class="num mono">
              <%= format_percent(r[:pct], digits: 1) %>
              <span class="muted" style="display: inline-block; vertical-align: middle; margin-left: 6px;
                                          background: #e0e0e0; height: 8px; width: 80px; position: relative">
                <span style="display: block; height: 100%; width: <%= (r[:pct] * 100).round(1) %>%;
                             background: <%= AccountClassifier.kind_color(r[:kind]) %>"></span>
              </span>
            </td>
            <td class="num mono"><%= r[:count] %></td>
            <td class="muted" style="font-size: 0.85rem">
              <%= r[:top_holdings].first(3).map { |h| "<a href='/analysis/#{h[:symbol]}'>#{h[:symbol]}</a>" }.join(' &middot; ') %>
              <% if r[:top_holdings].length > 3 %>
                &middot; +<%= r[:top_holdings].length - 3 %> more
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <p class="data-source">
      Tax kind classification follows the broker account name (Roth IRA, 401(k) / 403(b), Traditional IRA, etc.).
      <% if @account_breakdown[:multi_account_positions] && @account_breakdown[:multi_account_positions] > 0 %>
        <strong><%= @account_breakdown[:multi_account_positions] %> position<%= @account_breakdown[:multi_account_positions] == 1 ? '' : 's' %> span<%= @account_breakdown[:multi_account_positions] == 1 ? 's' : '' %> multiple accounts</strong>
        — value is split evenly across accounts (a v1 approximation, ~&lt;1% of typical portfolios).
      <% end %>
      Account-type visibility is the foundation for the planned Roth-conversion-window, RMD-projection, and tax-efficient-location features (TODOs U / V / W).
    </p>
  </section>
<% end %>

<% if @expense_audit && @expense_audit[:rows].any? %>
  <section class="benchmark-section" style="margin-top: 18px">
    <h3>
      Expense-ratio audit
      <span class="muted" style="font-size:0.78rem; font-weight:normal">
        &middot; <%= @expense_audit[:rows].length %> covered fund<%= @expense_audit[:rows].length == 1 ? '' : 's' %>
        <% if @expense_audit[:as_of] %>&middot; as of <%= @expense_audit[:as_of] %><% end %>
      </span>
    </h3>
    <div class="portfolio-summary">
      <div class="summary-card">
        <div class="summary-label">Annual fee drag</div>
        <div class="summary-value mono <%= @expense_audit[:total_known_fee] > 0 ? 'negative' : '' %>">
          <%= format_money(@expense_audit[:total_known_fee]) %>
        </div>
        <div class="summary-sub muted">across covered funds, per year</div>
      </div>
      <div class="summary-card">
        <div class="summary-label">Weighted average ER</div>
        <div class="summary-value mono"><%= format_percent(@expense_audit[:weighted_avg_ratio], digits: 2) %></div>
        <div class="summary-sub muted">on <%= format_money(@expense_audit[:total_known_value]) %> covered</div>
      </div>
      <div class="summary-card">
        <div class="summary-label">Coverage</div>
        <div class="summary-value mono">
          <%= ((@expense_audit[:total_known_value] / (@expense_audit[:total_known_value] + @expense_audit[:unknown][:value])) * 100).round(1) %>%
        </div>
        <div class="summary-sub muted">
          <%= @expense_audit[:unknown][:count] %> position<%= @expense_audit[:unknown][:count] == 1 ? '' : 's' %>
          (<%= format_money(@expense_audit[:unknown][:value]) %>) unknown
        </div>
      </div>
    </div>
    <details class="positions-collapsible" style="margin-top: 12px">
      <summary class="positions-collapsible-summary">
        <span class="positions-chevron" aria-hidden="true">▸</span>
        <span class="positions-summary-text">
          <strong>Top 25 fee-drag positions</strong>
          <span class="muted">— click to show / hide</span>
        </span>
      </summary>
      <table class="data-table" style="margin-top: 10px">
        <thead>
          <tr>
            <th>Symbol</th>
            <th>Description</th>
            <th class="num">Value</th>
            <th class="num">ER</th>
            <th class="num">Annual fee</th>
          </tr>
        </thead>
        <tbody>
          <% @expense_audit[:rows].first(25).each do |r| %>
            <tr>
              <td><a href="/analysis/<%= r[:symbol] %>"><%= r[:symbol] %></a></td>
              <td class="muted" style="font-size: 0.85rem"><%= r[:description] %></td>
              <td class="num mono"><%= format_money(r[:value]) %></td>
              <td class="num mono <%= r[:expense_ratio] >= 0.005 ? 'negative' : (r[:expense_ratio] >= 0.0025 ? '' : 'positive') %>">
                <%= format_percent(r[:expense_ratio], digits: 2) %>
              </td>
              <td class="num mono <%= r[:annual_fee] >= 100 ? 'negative' : '' %>"><%= format_money(r[:annual_fee]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </details>
    <p class="data-source">
      Annual fee = position market value × the fund's prospectus expense ratio. We carry a curated table of <%= ExpenseRatioMap.coverage_count %> common ETFs and mutual funds; uncovered positions (individual stocks, niche funds, CUSIPs) are reported in the "unknown" bucket and excluded from the totals — extending <code>app/expense_ratio_map.rb</code> is where to add coverage. ≥0.50% ER is shown in red as a rough fee-drag heuristic; ≤0.25% in green.
    </p>
  </section>
<% end %>

<section class="benchmark-section" style="margin-top: 18px">
  <h3>
    Retirement planning
    <span class="muted" style="font-size:0.78rem; font-weight:normal">
      &middot; <a href="/portfolio/tax-harvest">edit profile →</a>
    </span>
  </h3>
  <% if @retirement %>
    <%
      verdict_class =
        case @retirement[:verdict]
        when :on_track_safe, :on_track_balanced, :at_goal then 'positive'
        when :tight_equity                                then ''
        else                                                   'negative'
        end
      sp = @retirement[:spending]
      sp_class =
        if sp.nil? then nil
        else
          case sp[:verdict]
          when :perpetual, :comfortable, :thirty_year_safe then 'positive'
          when :tight                                       then ''
          else                                                   'negative'
          end
        end
    %>
    <div class="portfolio-summary">
      <div class="summary-card">
        <div class="summary-label">Years remaining</div>
        <div class="summary-value mono"><%= @retirement[:years_remaining] %></div>
        <div class="summary-sub muted">until retirement age</div>
      </div>
      <div class="summary-card">
        <div class="summary-label">Required annual return</div>
        <% if @retirement[:status] == 'at_goal' %>
          <div class="summary-value mono positive">0.0%</div>
        <% else %>
          <div class="summary-value mono <%= verdict_class %>">
            <%= format_percent(@retirement[:nominal_required_return], digits: 2) %>
          </div>
        <% end %>
        <div class="summary-sub muted">nominal CAGR</div>
      </div>
      <div class="summary-card">
        <div class="summary-label">Years portfolio lasts</div>
        <% if sp.nil? %>
          <div class="summary-value mono muted">—</div>
          <div class="summary-sub muted">set monthly spending →</div>
        <% elsif sp[:years_portfolio_lasts].infinite? %>
          <div class="summary-value mono positive">Indefinite</div>
          <div class="summary-sub muted">@ <%= format_percent(sp[:withdrawal_rate]) %> withdrawal</div>
        <% else %>
          <% yrs = sp[:years_portfolio_lasts].round %>
          <div class="summary-value mono <%= sp_class %>"><%= yrs %> yrs</div>
          <div class="summary-sub muted">@ <%= format_percent(sp[:withdrawal_rate]) %> withdrawal</div>
        <% end %>
      </div>
    </div>
    <p style="margin-top: 12px; font-size: 0.92rem">
      <strong class="<%= verdict_class %>"><%= @retirement[:verdict_summary].split('.').first %>.</strong>
      <% if sp && sp[:verdict_summary] %>
        <strong class="<%= sp_class %>"><%= sp[:verdict_summary].split('.').first %>.</strong>
      <% end %>
      <a href="/portfolio/retirement" class="btn-primary" style="display:inline-block; margin-left:8px; padding:4px 12px; font-size:0.85rem">
        See full projection &amp; verdict →
      </a>
    </p>
  <% else %>
    <p class="data-source">
      Set your current age, retirement age, and target on
      <a href="/portfolio/tax-harvest">the profile form</a> to enable the projection.
      <a href="/portfolio/retirement">→ Open retirement planning page</a>
    </p>
  <% end %>
</section>


<% if @rows.empty? %>
  <div class="notice">No open positions. Buy your first lot below.</div>
<% else %>
  <section class="portfolio-summary">
    <div class="summary-card">
      <div class="summary-label">Market Value</div>
      <div class="summary-value mono"><%= format_money(@totals[:market_value]) %></div>
    </div>
    <div class="summary-card">
      <div class="summary-label">Cost Basis</div>
      <div class="summary-value mono"><%= format_money(@totals[:cost_value]) %></div>
    </div>
    <div class="summary-card">
      <div class="summary-label">Unrealized P&amp;L</div>
      <div class="summary-value mono <%= @totals[:unrealized_pl] >= 0 ? 'positive' : 'negative' %>">
        <%= format_money(@totals[:unrealized_pl]) %>
        <% if @totals[:unrealized_pl_pct] %>
          <span class="summary-sub">(<%= format_percent(@totals[:unrealized_pl_pct]) %>)</span>
        <% end %>
      </div>
    </div>
    <div class="summary-card">
      <div class="summary-label">Realized P&amp;L (YTD)</div>
      <div class="summary-value mono <%= @realized_ytd >= 0 ? 'positive' : 'negative' %>">
        <%= format_money(@realized_ytd) %>
      </div>
    </div>
    <div class="summary-card">
      <div class="summary-label">Positions</div>
      <div class="summary-value mono"><%= @totals[:positions_count] %></div>
    </div>
  </section>

  <% if @benchmark && @benchmark[:portfolio_return] %>
    <section class="benchmark-section">
      <h3>Benchmark Comparison</h3>
      <div class="portfolio-summary">
        <div class="summary-card">
          <div class="summary-label">Your portfolio return</div>
          <div class="summary-value mono <%= @benchmark[:portfolio_return] >= 0 ? 'positive' : 'negative' %>">
            <%= format_percent(@benchmark[:portfolio_return]) %>
          </div>
          <div class="summary-sub muted">Lot-weighted, since acquisition</div>
        </div>
        <div class="summary-card">
          <div class="summary-label"><%= @benchmark[:benchmark] %> over same window</div>
          <div class="summary-value mono <%= @benchmark[:benchmark_return] >= 0 ? 'positive' : 'negative' %>">
            <%= format_percent(@benchmark[:benchmark_return]) %>
          </div>
          <div class="summary-sub muted">If you'd held SPY at the same dates</div>
        </div>
        <div class="summary-card">
          <div class="summary-label">Alpha</div>
          <div class="summary-value mono <%= @benchmark[:alpha] >= 0 ? 'positive' : 'negative' %>">
            <%= format_percent(@benchmark[:alpha]) %>
          </div>
          <div class="summary-sub muted">Your return − benchmark</div>
        </div>
        <div class="summary-card">
          <div class="summary-label">Lots priced</div>
          <div class="summary-value mono">
            <%= @benchmark[:lots_priced] %>
            <% if @benchmark[:lots_skipped] && @benchmark[:lots_skipped] > 0 %>
              / <%= @benchmark[:lots_priced] + @benchmark[:lots_skipped] %>
            <% end %>
          </div>
          <% if @benchmark[:as_of] %>
            <div class="summary-sub muted">As of <%= @benchmark[:as_of] %></div>
          <% end %>
        </div>
      </div>
      <% if @benchmark[:lots_skipped] && @benchmark[:lots_skipped] > 0 %>
        <p class="data-source">
          <%= @benchmark[:lots_skipped] %> lot<%= @benchmark[:lots_skipped] == 1 ? '' : 's' %> skipped:
          either current price unavailable or no <%= @benchmark[:benchmark] %> bar at the lot's acquired date
          (Fidelity-imported lots without an explicit acquisition date fall back to the earliest snapshot — older
          lots may pre-date that and get excluded). All zero-cost-basis or no-shares lots are also skipped.
        </p>
      <% end %>
    </section>
  <% end %>

  <section class="benchmark-section">
    <h3>
      Realized P&amp;L (YTD by holding period) &middot; Tax + wash-sale
      <span class="muted" style="font-size:0.78rem; font-weight:normal">
        &middot; <a href="/portfolio/tax-harvest">Tax-loss harvesting →</a>
      </span>
    </h3>
    <div class="portfolio-summary">
      <div class="summary-card">
        <div class="summary-label">Short-term</div>
        <div class="summary-value mono <%= @realized_short_ytd > 0 ? 'positive' : (@realized_short_ytd < 0 ? 'negative' : '') %>">
          <%= format_money(@realized_short_ytd) %>
        </div>
        <div class="summary-sub muted">Held ≤ 1 yr · ordinary-income tax</div>
      </div>
      <div class="summary-card">
        <div class="summary-label">Long-term</div>
        <div class="summary-value mono <%= @realized_long_ytd > 0 ? 'positive' : (@realized_long_ytd < 0 ? 'negative' : '') %>">
          <%= format_money(@realized_long_ytd) %>
        </div>
        <div class="summary-sub muted">Held > 1 yr · cap-gains rate</div>
      </div>
      <div class="summary-card">
        <div class="summary-label">Total YTD</div>
        <div class="summary-value mono <%= @realized_ytd > 0 ? 'positive' : (@realized_ytd < 0 ? 'negative' : '') %>">
          <%= format_money(@realized_ytd) %>
        </div>
        <div class="summary-sub muted"><a href="/trades">All trades →</a></div>
      </div>
    </div>
    <% if @realized_short_ytd == 0 && @realized_long_ytd == 0 && @realized_ytd == 0 %>
      <p class="data-source">
        No realized gains or losses yet this year — these will populate once you record a SELL.
        Each closed lot is automatically tagged short-term (≤ 1 yr) or long-term (> 1 yr); the YTD
        split shows what flows where on your tax forms.
      </p>
    <% end %>
    <p class="data-source">
      <strong>Wash-sale warnings</strong> are surfaced on <a href="/trades">/trades</a> next to any SELL recorded
      at a loss when there's a same-symbol BUY within ±30 days. The <strong>Sell</strong> form on each row
      below also flags these on submit. Per-lot tax preview (would-be short / long if sold today) appears
      in each position's expandable lot detail.
    </p>
  </section>

  <details class="positions-collapsible">
    <summary class="positions-collapsible-summary">
      <span class="positions-chevron" aria-hidden="true">▸</span>
      <span class="positions-summary-text">
        <strong>All positions</strong>
        (<%= @rows.length %>)
        <span class="muted">— click to show / hide</span>
      </span>
    </summary>
  <table class="data-table portfolio-table">
    <thead>
      <tr>
        <th>Symbol</th>
        <th class="num">Shares</th>
        <th class="num">Avg Cost</th>
        <th class="num">Price</th>
        <th class="num">Market Value</th>
        <th class="num">Unrealized P&amp;L</th>
        <th class="num">P&amp;L %</th>
        <th class="num">Day</th>
        <th class="num">Weight</th>
        <th>Trend</th>
        <th>Signal</th>
        <th>Notes</th>
        <th class="num">Lots</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @rows.each do |r| %>
        <tr class="position-row" data-symbol="<%= r[:symbol] %>">
          <td><a href="/analysis/<%= r[:symbol] %>"><%= r[:symbol] %></a></td>
          <td class="num mono"><%= r[:shares] %></td>
          <td class="num mono">$<%= format('%.2f', r[:cost_basis]) %></td>
          <td class="num mono">
            <%= r[:current_price] ? "$#{format('%.2f', r[:current_price])}" : '—' %>
          </td>
          <td class="num mono"><%= r[:market_value] ? format_money(r[:market_value]) : '—' %></td>
          <td class="num mono <%= r[:unrealized_pl] && r[:unrealized_pl] >= 0 ? 'positive' : (r[:unrealized_pl] && r[:unrealized_pl] < 0 ? 'negative' : '') %>">
            <%= r[:unrealized_pl] ? format_money(r[:unrealized_pl]) : '—' %>
          </td>
          <td class="num mono <%= r[:unrealized_pl_pct] && r[:unrealized_pl_pct] >= 0 ? 'positive' : (r[:unrealized_pl_pct] && r[:unrealized_pl_pct] < 0 ? 'negative' : '') %>">
            <%= r[:unrealized_pl_pct] ? format_percent(r[:unrealized_pl_pct]) : '—' %>
          </td>
          <td class="num mono"><%= r[:day_change] || '—' %></td>
          <td class="num mono"><%= r[:weight] ? format_percent(r[:weight], digits: 1) : '—' %></td>
          <td>
            <% sym_series = (@history_per_sym && @history_per_sym[r[:symbol]]) || [] %>
            <% if sym_series.length >= 2 %>
              <% first_val = sym_series.first[:market_value].to_f %>
              <% last_val  = sym_series.last[:market_value].to_f %>
              <% sym_change = (last_val - first_val).round(2) %>
              <% sym_change_pct = first_val.positive? ? ((last_val - first_val) / first_val) : nil %>
              <span title="<%= sym_series.length %> snapshots · <%= sym_series.first[:date] %> → <%= sym_series.last[:date] %> · <%= format_money(sym_change) %><%= sym_change_pct ? " (#{format_percent(sym_change_pct)})" : '' %>">
                <%= PortfolioHistory.sparkline_svg(sym_series) %>
              </span>
            <% else %>
              <span class="muted">—</span>
            <% end %>
          </td>
          <td>
            <span class="signal-badge signal-<%= (r[:recommendation] || 'HOLD').downcase %>">
              <%= r[:recommendation] || 'HOLD' %>
            </span>
          </td>
          <td class="muted">
            <% (r[:notes_extra] || []).each_with_index do |n, i| %>
              <%= '· ' if i > 0 %><%= n %>
            <% end %>
          </td>
          <td class="num mono">
            <button type="button" class="link-btn lot-toggle" data-target="lots-<%= r[:symbol] %>"
                    aria-expanded="false" title="Show / hide individual lots">
              <%= r[:lots].length %> ▾
            </button>
          </td>
          <td>
            <form action="/portfolio/remove" method="post" style="margin:0">
              <input type="hidden" name="symbol" value="<%= r[:symbol] %>">
              <button type="submit" class="link-btn"
                      title="Remove ALL lots for this symbol without recording a trade (typo-correction). To realise P&L, use Sell below."
                      onclick="return confirm('Remove all lots for <%= r[:symbol] %> without realising P&amp;L? This is for typo correction — to record a sale, use Sell instead.');">
                ✕
              </button>
            </form>
          </td>
        </tr>

        <!-- Expandable lot detail row -->
        <tr id="lots-<%= r[:symbol] %>" class="lot-detail-row" hidden>
          <td colspan="14">
            <div class="lot-detail-wrap">
              <table class="lot-detail-table">
                <thead>
                  <tr>
                    <th>Acquired</th>
                    <th class="num">Shares</th>
                    <th class="num">Cost Basis</th>
                    <th class="num">Lot Cost</th>
                    <th class="num">Lot Value</th>
                    <th class="num">Lot P&amp;L</th>
                    <th>Tax (if sold today)</th>
                    <th>Notes</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  <% r[:lots].sort_by { |l| l[:acquired_at] || l[:created_at] }.each do |lot| %>
                    <% lot_cost  = (lot[:shares].to_f * lot[:cost_basis].to_f).round(2) %>
                    <% lot_value = r[:current_price] ? (lot[:shares].to_f * r[:current_price].to_f).round(2) : nil %>
                    <% lot_pl    = lot_value ? (lot_value - lot_cost).round(2) : nil %>
                    <% tax_today = TaxLot.classify(lot: lot, sold_at: Date.today.iso8601) %>
                    <% days_to_long = tax_today[:holding_period] == 'short' && tax_today[:days_held] ?
                                       (TaxLot::LONG_TERM_THRESHOLD_DAYS + 1 - tax_today[:days_held]) : nil %>
                    <tr>
                      <td><%= lot[:acquired_at] || lot[:created_at][0,10] %></td>
                      <td class="num mono"><%= lot[:shares] %></td>
                      <td class="num mono">$<%= format('%.2f', lot[:cost_basis]) %></td>
                      <td class="num mono"><%= format_money(lot_cost) %></td>
                      <td class="num mono"><%= lot_value ? format_money(lot_value) : '—' %></td>
                      <td class="num mono <%= lot_pl && lot_pl >= 0 ? 'positive' : (lot_pl && lot_pl < 0 ? 'negative' : '') %>">
                        <%= lot_pl ? format_money(lot_pl) : '—' %>
                      </td>
                      <td>
                        <span class="signal-badge holding-<%= tax_today[:holding_period] %>"><%= tax_today[:holding_period] %></span>
                        <% if tax_today[:days_held] %>
                          <span class="muted" style="font-size:0.78rem">
                            held <%= tax_today[:days_held] %>d
                            <% if days_to_long && days_to_long > 0 %>
                              · long-term in <%= days_to_long %>d
                            <% end %>
                          </span>
                        <% end %>
                        <% if tax_today[:source] == 'snapshot' %>
                          <span class="muted" style="font-size:0.72rem" title="Acquisition date inferred from earliest broker snapshot">(inferred)</span>
                        <% end %>
                      </td>
                      <td class="muted"><%= lot[:notes] %></td>
                      <td>
                        <form action="/lots/remove" method="post" style="margin:0">
                          <input type="hidden" name="id" value="<%= lot[:id] %>">
                          <button type="submit" class="link-btn"
                                  title="Remove this lot without recording a trade (typo correction)"
                                  onclick="return confirm('Remove this lot without realising P&amp;L?');">
                            ✕
                          </button>
                        </form>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>

              <!-- Sell form: FIFO close across this symbol's open lots -->
              <form action="/portfolio/sell" method="post" class="sell-form">
                <input type="hidden" name="symbol" value="<%= r[:symbol] %>">
                <label>Sell <input type="number" step="0.000001" min="0.000001" max="<%= r[:shares] %>"
                                   name="shares" required placeholder="<%= r[:shares] %>">
                  shares</label>
                <label>at <input type="number" step="0.0001" min="0.0001" name="price" required
                                  value="<%= r[:current_price] %>"> $/share</label>
                <label>on <input type="date" name="sold_at"></label>
                <button type="submit" class="btn-primary">Sell (FIFO)</button>
                <span class="data-source">Closes oldest lots first; realises P&amp;L on the trade-history page.</span>
              </form>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </details>
<% end %>

<section class="portfolio-add">
  <h3>Buy a position</h3>
  <form action="/portfolio/buy" method="post" class="portfolio-form">
    <label>Symbol
      <input type="text" name="symbol" required autocomplete="off"
             placeholder="AAPL" maxlength="10">
    </label>
    <label>Shares
      <input type="number" step="0.000001" min="0.000001" name="shares" required placeholder="100">
    </label>
    <label>Cost basis ($/share)
      <input type="number" step="0.0001" min="0.0001" name="cost_basis" required placeholder="150.25">
    </label>
    <label>Acquired
      <input type="date" name="acquired_at">
    </label>
    <label class="full-width">Notes (optional)
      <input type="text" name="notes" maxlength="120" placeholder="Long-term hold">
    </label>
    <button type="submit" class="btn-primary">Buy</button>
  </form>
  <p class="data-source">
    Each Buy creates a new lot. To add to an existing position, just submit again — both lots remain
    visible (with their own cost basis) under the position's expandable detail.
  </p>
</section>
