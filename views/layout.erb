<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>T Money Terminal</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header>
    <span class="logo">T Money Terminal</span>
    <nav>
      <a href="/dashboard" class="<%= request.path_info == '/dashboard' || request.path_info == '/' ? 'active' : '' %>">Dashboard</a>
      <a href="/us" class="<%= request.path_info == '/us' ? 'active' : '' %>">US Markets</a>
      <a href="/japan" class="<%= request.path_info == '/japan' ? 'active' : '' %>">Japan</a>
      <a href="/europe" class="<%= request.path_info == '/europe' ? 'active' : '' %>">Europe</a>
    </nav>
    <button id="theme-toggle" onclick="toggleTheme()">🌙 Dark</button>
  </header>
  <main>
    <%= yield %>
  </main>
  <footer>
    <small>T Money Terminal &mdash; For informational purposes only. Not financial advice.</small>
  </footer>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="/app.js"></script>
</body>
</html>
