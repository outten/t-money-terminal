<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>T Money Terminal</title>
  <link rel="stylesheet" href="/style.css?v=<%= asset_mtime('public/style.css') %>">
</head>
<body>
  <header>
    <span class="logo">T Money Terminal</span>
    <nav>
      <a href="/dashboard" class="<%= request.path_info == '/dashboard' || request.path_info == '/' ? 'active' : '' %>">Dashboard</a>
      <a href="/region/us" class="<%= %w[/us /region/us].include?(request.path_info) ? 'active' : '' %>">US Markets</a>
      <a href="/region/japan" class="<%= %w[/japan /region/japan].include?(request.path_info) ? 'active' : '' %>">Japan</a>
      <a href="/region/europe" class="<%= %w[/europe /region/europe].include?(request.path_info) ? 'active' : '' %>">Europe</a>
      <a href="/compare" class="<%= request.path_info == '/compare' ? 'active' : '' %>">Compare</a>
      <a href="/portfolio" class="<%= request.path_info == '/portfolio' ? 'active' : '' %>">Portfolio</a>
    </nav>
    <div class="search-box" role="search">
      <input type="text" id="symbol-search" placeholder="Search symbols…"
             autocomplete="off" spellcheck="false" aria-label="Search symbols">
      <ul id="symbol-search-results" class="search-results" hidden></ul>
    </div>
    <button id="theme-toggle" onclick="toggleTheme()">🌙 Dark</button>
  </header>
  <main>
    <%= yield %>
  </main>
  <footer>
    <small>T Money Terminal &mdash; For informational purposes only. Not financial advice.</small>
    <% if @cache_updated_at %>
      <small class="footer-freshness">Data as of <%= @cache_updated_at.strftime('%H:%M') %></small>
    <% end %>
  </footer>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://unpkg.com/lightweight-charts@4.2.0/dist/lightweight-charts.standalone.production.js"></script>
  <script src="/app.js?v=<%= asset_mtime('public/app.js') %>"></script>
  <script src="/features.js?v=<%= asset_mtime('public/features.js') %>"></script>
</body>
</html>
